from moabb.datasets import BNCI2014_001
from moabb.paradigms import MotorImagery
from mne.decoding import CSP
from sklearn.discriminant_analysis import LinearDiscriminantAnalysis as LDA
from sklearn.discriminant_analysis import QuadraticDiscriminantAnalysis as QDA
from sklearn.pipeline import Pipeline
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
import seaborn as sns

### PHASE ONE fragment

dataset = BNCI2014_001()
paradigm = MotorImagery(
    events=["left_hand","right_hand"],
    n_classes=2,           # Binary simplification (Left vs. Right)
    fmin=8.0, fmax=32.0,   # Bandpass filter (Alpha/Beta bands)
    tmin=0.5, tmax=2.5     # Epoching (0.5s to 2.5s post-cue)
)

dataset.subject_list = [1]

# X = The EEG signals (Trials x Channels x Time)
# y = The labels ('left_hand' or 'right_hand')
X, y, metadata = paradigm.get_data(dataset=dataset, subjects=[1])

# Step 0.1: Separate training and testing data
train_mask = metadata['session'] == '0train'
test_mask  = metadata['session'] == '1test'

X_train_all = X[train_mask]
y_train_all = y[train_mask]

X_test = X[test_mask]
y_test = y[test_mask]

### PHASE TWO

# Slicing the data:
# write the function
def slice_trial(trial_data, window_size, step_size):
    #initialize empty list
    chunks = []

    #initial start_index and end_index, created outside loop and updated inside it
    start_index = 0
    end_index = start_index + window_size

    #define data size
    total_length = trial_data.shape[1]  # number of timepoints

    #create the loop
    while end_index <= total_length:

        #slice the data
        chunk = trial_data[:, start_index:end_index]
        chunks.append(chunk)

        #update the indexes
        start_index += step_size
        end_index = start_index + window_size
    #return the new data
    return np.array(chunks)

# Majority vote
def majority_vote(predictions):
    values, counts = np.unique(predictions, return_counts=True)
    return values[np.argmax(counts)]

### PHASE THREE
def slice_trials(X_train, y_train, window_size, step_size):
    #Step 1: Create new empty lists
    new_X = []
    new_y = []

    #Step 2: Loop through the training data and slice each one and tag each window with that trial's original label
    for trial, label in zip(X_train, y_train):
        trial_chunks = slice_trial(trial, window_size, step_size)  # (n_chunks, channels, window_size)
        new_X.append(trial_chunks)
        new_y.extend([label] * trial_chunks.shape[0])  # repeat the label once per chunk

    #flatten the per-trial chunk arrays into one big matrix
    X_train_sliced = np.vstack(new_X)

    #convert to a numpy array
    y_train_sliced = np.array(new_y)

    return X_train_sliced, y_train_sliced

### another PHASE ONE fragment

# Step 2: Prepare storage
lda_accuracies = []
qda_accuracies = []

windows = np.arange(0.9, 0.1, -0.05)          # [0.9, 0.85, 0.8..., 0.6]
steps   = np.arange(0.03, 0.6, 0.03)          # [0.03, 0.06, ..., 0.57]
slice_parameters = [(w, s) for w in windows for s in steps if s < w and s + w < 1]

#Step 3: Start a loop
for window,step in slice_parameters:
    # Step 4: Slice the data
    X_train_sliced, y_train_sliced = slice_trials(X_train_all[:20], y_train_all[:20], round(window*X_train_all.shape[2]), round(step*X_train_all.shape[2]))

    # Step 5: Constructing the LDA pipeline
    lda_pipeline = Pipeline([
        ('csp', CSP(n_components=4, reg=None, log=True)),
        ('lda', LDA())
    ])

    # Step 6: Constructing the QDA pipeline
    qda_pipeline = Pipeline([
        ('csp', CSP(n_components=4, reg=None, log=True)),
        ('qda', QDA(reg_param=0.1))
    ])

    lda_pipeline.fit(X_train_sliced, y_train_sliced)   # CSP learns filters, LDA learns boundaries
    qda_pipeline.fit(X_train_sliced, y_train_sliced)

    lda_iter_acc = []
    for Xtrial, Ytrial in zip(X_test, y_test):
        newX, _ = slice_trials([Xtrial], [Ytrial], round(window*X_train_all.shape[2]), round(step*X_train_all.shape[2]))
        lda_predict = lda_pipeline.predict(newX)  # predict on test, compare to Ytrial
        lda_predict = majority_vote(lda_predict)
        lda_acc = int(lda_predict == Ytrial)
        lda_iter_acc.append(lda_acc)
    lda_accuracies.append(sum(lda_iter_acc)/len(lda_iter_acc))

    qda_iter_acc = []
    for Xtrial, Ytrial in zip(X_test, y_test):
        newX, _ = slice_trials([Xtrial], [Ytrial], round(window*X_train_all.shape[2]), round(step*X_train_all.shape[2]))
        qda_predict = qda_pipeline.predict(newX)  # predict on test, compare to Ytrial
        qda_predict = majority_vote(qda_predict)
        qda_acc = int(qda_predict == Ytrial)
        qda_iter_acc.append(qda_acc)
    qda_accuracies.append((sum(qda_iter_acc)/len(qda_iter_acc)))

#testing alternate display method

results_df = pd.DataFrame({
    'Window': [round(p[0], 2) for p in slice_parameters],
    'Step': [round(p[1], 2) for p in slice_parameters],
    'LDA': lda_accuracies,
    'QDA': qda_accuracies
})

lda_pivot = results_df.pivot(index='Window', columns='Step', values='LDA')
plt.figure(figsize=(12, 8))
sns.heatmap(lda_pivot, annot=True, cmap='YlGnBu')
plt.title('LDA Accuracy: Window and Step Size (20 trials)')
plt.show()

qda_pivot = results_df.pivot(index='Window', columns='Step', values='QDA')
plt.figure(figsize=(12, 8))
sns.heatmap(qda_pivot, annot=True, cmap='YlGnBu')
plt.title('QDA Accuracy: Window and Step Size (20 trials)')
plt.show()

lda_top_2_accuracies = results_df['LDA'].sort_values(ascending=False).unique()[:2]
qda_top_2_accuracies = results_df['QDA'].sort_values(ascending=False).unique()[:2]

# Get all rows that match the top 2 accuracy values
lda_top_results_df = results_df[results_df['LDA'].isin(lda_top_2_accuracies)].sort_values(by='LDA', ascending=False)
qda_top_results_df = results_df[results_df['QDA'].isin(qda_top_2_accuracies)].sort_values(by='QDA', ascending=False)

# Combine unique (Window, Step) pairs from both LDA and QDA top results
combined_top_parameters = pd.concat([
    lda_top_results_df[['Window', 'Step']],
    qda_top_results_df[['Window', 'Step']]
]).drop_duplicates().values.tolist()

# Initialize new lists to store accuracies for these specific top parameters
lda_all_subjects_accuracies_top = []
qda_all_subjects_accuracies_top = []
lda_all_subjects_acc_no_aug = []
qda_all_subjects_acc_no_aug = []

dataset = BNCI2014_001()
paradigm = MotorImagery(
    events=["left_hand","right_hand"],
    n_classes=2,           # Binary simplification (Left vs. Right)
    fmin=8.0, fmax=32.0,   # Bandpass filter (Alpha/Beta bands)
    tmin=0.5, tmax=2.5     # Epoching (0.5s to 2.5s post-cue)
)

# X = The EEG signals (Trials x Channels x Time)
# y = The labels ('left_hand' or 'right_hand')

for subject_id in dataset.subject_list:
  X, y, metadata = paradigm.get_data(dataset=dataset, subjects=[subject_id])

  # Step 0.1: Separate training and testing data
  train_mask = metadata['session'] == '0train'
  test_mask  = metadata['session'] == '1test'

  X_train_all = X[train_mask]
  y_train_all = y[train_mask]

  X_test = X[test_mask]
  y_test = y[test_mask]

  qda_accuracies_top_for_subject = []
  lda_accuracies_top_for_subject = []

  for window, step in combined_top_parameters:
      # Step 4: Slice the data
      # Ensure window and step are floats for calculations
      X_train_sliced, y_train_sliced = slice_trials(X_train_all[:20], y_train_all[:20], round(float(window)*X_train_all.shape[2]), round(float(step)*X_train_all.shape[2]))

      # Step 5: Constructing the LDA pipeline
      lda_pipeline = Pipeline([
          ('csp', CSP(n_components=4, reg=None, log=True)),
          ('lda', LDA())
      ])

      # Step 6: Constructing the QDA pipeline
      qda_pipeline = Pipeline([
          ('csp', CSP(n_components=4, reg=None, log=True)),
          ('qda', QDA(reg_param=0.1))
      ])

      lda_pipeline.fit(X_train_sliced, y_train_sliced)   # CSP learns filters, LDA learns boundaries
      qda_pipeline.fit(X_train_sliced, y_train_sliced)

      lda_iter_acc = []
      for Xtrial, Ytrial in zip(X_test, y_test):
          newX, _ = slice_trials([Xtrial], [Ytrial], round(float(window)*X_train_all.shape[2]), round(float(step)*X_train_all.shape[2]))
          lda_predict = lda_pipeline.predict(newX)  # predict on test, compare to Ytrial
          lda_predict = majority_vote(lda_predict)
          lda_acc = int(lda_predict == Ytrial)
          lda_iter_acc.append(lda_acc)
      lda_accuracies_top_for_subject.append(sum(lda_iter_acc)/len(lda_iter_acc))

      qda_iter_acc = []
      for Xtrial, Ytrial in zip(X_test, y_test):
          newX, _ = slice_trials([Xtrial], [Ytrial], round(float(window)*X_train_all.shape[2]), round(float(step)*X_train_all.shape[2]))
          qda_predict = qda_pipeline.predict(newX)  # predict on test, compare to Ytrial
          qda_predict = majority_vote(qda_predict)
          qda_acc = int(qda_predict == Ytrial)
          qda_iter_acc.append(qda_acc)
      qda_accuracies_top_for_subject.append((sum(qda_iter_acc)/len(qda_iter_acc)))
  lda_all_subjects_accuracies_top.append(lda_accuracies_top_for_subject)
  qda_all_subjects_accuracies_top.append(qda_accuracies_top_for_subject)
  
  # reconstruct pipelines for no aug
  lda_pipeline = Pipeline([
      ('csp', CSP(n_components=4, reg=None, log=True)),
      ('lda', LDA())
  ])

  qda_pipeline = Pipeline([
      ('csp', CSP(n_components=4, reg=None, log=True)),
      ('qda', QDA(reg_param=0.1))
  ])

  # test no aug
  lda_pipeline.fit(X_train_all[:20], y_train_all[:20])   # CSP learns filters, LDA learns boundaries
  qda_pipeline.fit(X_train_all[:20], y_train_all[:20])

  lda_iter_acc = []
  for Xtrial, Ytrial in zip(X_test, y_test):
      lda_predict = lda_pipeline.predict(Xtrial[np.newaxis])[0]  # predict on test, compare to Ytrial
      lda_acc = int(lda_predict == Ytrial)
      lda_iter_acc.append(lda_acc)
  lda_all_subjects_acc_no_aug.append(sum(lda_iter_acc)/len(lda_iter_acc))

  qda_iter_acc = []
  for Xtrial, Ytrial in zip(X_test, y_test):
      qda_predict = qda_pipeline.predict(Xtrial[np.newaxis])[0]  # predict on test, compare to Ytrial
      qda_acc = int(qda_predict == Ytrial)
      qda_iter_acc.append(qda_acc)
  qda_all_subjects_acc_no_aug.append((sum(qda_iter_acc)/len(qda_iter_acc)))

# Transpose the list of lists to get accuracies per parameter across subjects
lda_accuracies_per_parameter = np.array(lda_all_subjects_accuracies_top).T.tolist()
qda_accuracies_per_parameter = np.array(qda_all_subjects_accuracies_top).T.tolist()

# Calculate mean and standard deviation across subjects for each parameter combination
lda_mean_accuracies = [np.mean(accs) for accs in lda_accuracies_per_parameter]
lda_std_accuracies = [np.std(accs) for accs in lda_accuracies_per_parameter]
qda_mean_accuracies = [np.mean(accs) for accs in qda_accuracies_per_parameter]
qda_std_accuracies = [np.std(accs) for accs in qda_accuracies_per_parameter]

# Create a DataFrame to display the results for the top parameters
top_results_summary = pd.DataFrame({
    'Window': [p[0] for p in combined_top_parameters],
    'Step': [p[1] for p in combined_top_parameters],
    'LDA Mean Accuracy': lda_mean_accuracies,
    'LDA Standard deviation': lda_std_accuracies,
    'QDA Mean Accuracy': qda_mean_accuracies,
    'QDA Standard deviation': qda_std_accuracies
})

no_aug_row = pd.DataFrame([{
    'Window': 'No Aug',
    'Step': 'No Aug',
    'LDA Mean Accuracy': np.mean(lda_all_subjects_acc_no_aug),
    'LDA Standard deviation': np.std(lda_all_subjects_acc_no_aug),
    'QDA Mean Accuracy': np.mean(qda_all_subjects_acc_no_aug),
    'QDA Standard deviation': np.std(qda_all_subjects_acc_no_aug)
}])

top_results_summary = pd.concat([no_aug_row, top_results_summary], ignore_index=True)

print("Re-evaluated Mean and Std Accuracies for Top (Window, Step) Parameters (across subjects):")
display(top_results_summary)
